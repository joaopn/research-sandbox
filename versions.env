# Image version pins (single source of truth).
#
# Every per-image `ARG <NAME>=<default>` in agent/Dockerfile.* keeps its
# default as a standalone-build fallback, but `_build_images` in research.py
# reads THIS file and passes each value as `docker build --build-arg`, so the
# numbers here win for every image the substrate builds.
#
# Workflow (mirrors the DOCKER_VERSION discipline):
#   edit a pin -> `python research.py start --rebuild` -> destroy+recreate
#   affected projects (a rebuild does not reach existing projects until they
#   are recreated / _recreate_supervisor re-stages the image).
# Revert = `git checkout versions.env` + rebuild. Git is the version control;
# there is no bespoke upgrade/revert command by design — with TWO sanctioned
# exceptions: `research agent refresh` writes CLAUDE_CODE_VERSION (the agent-dist
# pin) and `research editor refresh` writes CODE_SERVER_VERSION (the editor-dist
# pin); each checks upstream, offers to bump the pin, and re-pulls the dist
# (STAGE_AGENT_DIST / STAGE_EDITOR_DIST). You still review + commit.
#
# Format: KEY=VALUE, one per line, `#` comments on their own lines. Parsed by
# load_versions() with the stdlib (no TOML — research.py targets Python 3.9+).

# code-server 4.123.0 bundles VS Code 1.123.0. In slice 1 this serves BOTH the
# minimal-base bake AND the editor dist (`research editor pull` — STAGE_EDITOR_DIST);
# same value, they must agree (the build-arg self-prune fires only at slice 2 when
# the bake's ARG is deleted). `research editor refresh` is the sanctioned writer.
# Two caveats before bumping:
#   - the strip list (a fixed set of built-in extensions by directory name) lives
#     in BOTH Dockerfile.minimal-base AND rscore._CODE_SERVER_STRIP_EXTS (the dist
#     build) — keep them in lockstep; a major code-server bump can rename/drop
#     those, so revalidate the Editor tab after a bump.
#   - extensions checking `engines.vscode` (e.g. anthropic.claude-code) are
#     gated by the *bundled VS Code* version, not the code-server version.
CODE_SERVER_VERSION=4.123.0

# Inner docker-ce, installed via get.docker.com. Bumps are deliberate (inner
# dockerd runs under sysbox; crun is the inner OCI runtime).
DOCKER_VERSION=29.5.3

# MS-marketplace-only Data Wrangler VSIX, pre-staged for first-boot install. Like
# CODE_SERVER_VERSION, slice 1 feeds it to BOTH the bake AND the editor dist (the
# dist downloads this .vsix fresh in-container at `editor pull`).
DATA_WRANGLER_VERSION=1.24.2

# Claude Code CLI pin for the host AGENT DIST (no longer a Dockerfile build-arg —
# the bake was removed in STAGE_AGENT_DIST slice 2; no image bakes claude). This
# is the version `research agent pull` builds into ~/.research-sandbox/agent-dist/
# and that every container (supervisor + worker/role-MCP/PI/sandbox-box) deploys
# via `cp` at boot. Bump it with `research agent refresh` (the sanctioned writer;
# it checks upstream, offers to bump, re-pulls), then re-`pull` is implicit. A
# `project update-agent` / recreate re-stages the new dist into a running project.
CLAUDE_CODE_VERSION=2.1.170

# Image-baked stdio MCP / pip pins shared across role-MCP + sandbox-box-browser
# + PI websearcher images. Single home here kills the former triplication.
PLAYWRIGHT_MCP_VERSION=0.0.76
PYYAML_VERSION=6.0.3
AIOHTTP_VERSION=3.14.1
