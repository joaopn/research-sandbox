# research-sandbox configuration. Copy to .env and edit.

# Directory for project workspaces on the host.
# Each project's /workspace is bind-mounted from <PROJECTS_DIR>/<project>/workspace/.
# Default (when unset): <repo>/container_volumes/.
# `project destroy` deletes <PROJECTS_DIR>/<project>/ recursively, including
# the .claude/.credentials.json snapshot.
PROJECTS_DIR=./container_volumes/

# DNS servers for supervisor and worker containers (comma-separated, publicly routable).
# Defaults to Quad9. Required.
SANDBOX_DNS=9.9.9.9,149.112.112.112

# Default memory limit for supervisor containers (Docker size string, e.g. 8g).
# DEFAULT_MEMORY=

# Default image profile for the supervisor (only "python" in Stage 1).
DEFAULT_PROFILE=python

# DIND mode: sysbox | privileged | auto (default: auto — prefers sysbox if installed).
# Forces all supervisors to use the given runtime. CLI --dind flag overrides per-project.
# DEFAULT_DIND=auto

# Default egress policy at the host-side router: open | locked (default: open).
# Stage 1 research workloads generally need open (pip install etc.). Tighten per-project
# with `research project create --egress locked` when you want restriction.
# DEFAULT_EGRESS=open

# Webui (optional browser UI; opt-in via `research webui start`).
# Defaults bind to localhost only. Override BIND to expose on the LAN
# (e.g. WEBUI_BIND=0.0.0.0); the self-signed cert auto-rotates to cover
# the new bind. `research webui start --bind <ip>` updates this in place.
# WEBUI_BIND=127.0.0.1
# WEBUI_PORT=7777

# code-server lazy-reap idle window. The browser editor process gets
# SIGTERM'd after this many seconds without an active connection;
# the next request respawns it (~3-5s cold start). Default in the
# entrypoint is 1800s (30 min). Tune up if cold-start respawns
# annoy you, down if RAM pressure across N projects bites.
# CODE_SERVER_IDLE_SECONDS=1800
