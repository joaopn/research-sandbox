FROM rs-pi-base:latest

# pi-websearcher — interactive PI-mode browser-driven web-research tab.
# FROMs rs-pi-base (analysis-base + byobu + entrypoint.pi.sh) and bakes in
# the Playwright/Chromium stack identically to the worker-facing
# rs-websearcher image. PI mode = long-lived byobu session, conversational
# claude in the loop, multi-turn iteration. Worker-facing mode = fire-and-
# forget per-call `claude -p` spawns.
#
# Substrate split mirrors entrypoint.role-mcp.sh's image-baked extras
# merge: entrypoint.pi.sh discovers /opt/pi-templates/websearcher/
# extra-mcps.json at boot, merges it into /workspace/.mcp.json, and
# renders the "Image-baked tools" section of .tools-inventory.md via a
# live tools/list query against the launched Playwright server.
#
# PW1/PW2 cross-cut: this image REUSES container/role-mcp/websearcher/
# extra-mcps.yaml + render-extra-mcps.py as the single source of truth
# for the Playwright launch spec + WS2 deny list. A deny-list addition
# in one YAML file propagates to BOTH rs-websearcher and rs-pi-websearcher
# on rebuild. The PLAYWRIGHT_MCP_VERSION pin must stay in lockstep with
# Dockerfile.websearcher — bump both ARGs together. See `.claude/CLAUDE.md`
# rule "PW1 lockstep" and stage_p1_test.sh Phase 1.

USER root

# --- Pinned versions ---------------------------------------------------------
# Must match Dockerfile.websearcher's pins (PW1 lockstep). Bump both ARGs
# together; the P.1 test cross-checks the env-exposed version across both
# images and refuses to pass on drift.
ARG NODE_MAJOR=22
ARG PLAYWRIGHT_MCP_VERSION=0.0.76
ARG PYYAML_VERSION=6.0.3

# --- Node.js + dumb-init -----------------------------------------------------
# Same install posture as Dockerfile.websearcher. dumb-init wraps the
# Playwright stdio server at runtime so the Playwright -> Chromium ->
# renderer subprocess tree reaps cleanly when an interactive claude
# session exits (or byobu tab closes mid-call).
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs dumb-init && \
    rm -rf /var/lib/apt/lists/* && \
    node --version && npm --version && dumb-init --version

# --- pyyaml for the render step ---------------------------------------------
RUN /opt/conda/bin/pip install --no-cache-dir "pyyaml==${PYYAML_VERSION}"

# --- @playwright/mcp + Chromium runtime --------------------------------------
# Install at image-build per substrate SB3 — never `npx -y` at runtime.
# PLAYWRIGHT_BROWSERS_PATH puts Chromium in a system-wide location so the
# runtime `worker` user reads what the build-time root install wrote.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npm install -g "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" && \
    mkdir -p ${PLAYWRIGHT_BROWSERS_PATH} && \
    cd "$(npm root -g)/@playwright/mcp" && \
    PATH="$PWD/node_modules/.bin:$PATH" \
        playwright install --with-deps chromium && \
    chmod -R a+rX ${PLAYWRIGHT_BROWSERS_PATH} && \
    rm -rf /var/lib/apt/lists/*

# --- Role files --------------------------------------------------------------
# PI-mode role.md (conversational, no per-call template). The substrate
# stages this to /workspace/role.md on first boot and symlinks
# /workspace/CLAUDE.md -> role.md for claude auto-discovery.
COPY container/pi-websearcher/role.md /opt/pi-templates/websearcher/role.md
# Starting message (STAGE_SPAWN_GREETING), read by the Websearcher tab's greet
# helper on first open. Sibling to role.md; covered by the chown at the
# version-marker step below (chown -R /opt/pi-templates/websearcher).
COPY container/pi-websearcher/greeting /opt/pi-templates/websearcher/greeting

# --- Render the three image-baked JSON artifacts ----------------------------
# Reuse the worker-facing websearcher's YAML source-of-truth (PW2). The
# renderer is the same script; only the output paths differ (PI-specific
# template dir). Single deny-list source by construction.
COPY container/role-mcp/websearcher/extra-mcps.yaml         /tmp/extra-mcps.yaml
COPY container/role-mcp/websearcher/render-extra-mcps.py    /tmp/render-extra-mcps.py
RUN mkdir -p /etc/claude-code /opt/pi-templates/websearcher && \
    /opt/conda/bin/python3 /tmp/render-extra-mcps.py \
        --yaml                 /tmp/extra-mcps.yaml \
        --bin                  "$(command -v playwright-mcp)" \
        --out-extra            /opt/pi-templates/websearcher/extra-mcps.json \
        --out-config           /opt/pi-templates/websearcher/playwright-mcp-config.json \
        --out-managed-settings /etc/claude-code/managed-settings.json && \
    chmod 644 /etc/claude-code/managed-settings.json && \
    rm /tmp/extra-mcps.yaml /tmp/render-extra-mcps.py

# --- Version marker + permissions -------------------------------------------
RUN echo "${PLAYWRIGHT_MCP_VERSION}" > /opt/pi-templates/websearcher/.playwright-mcp-version && \
    chown -R worker:worker /opt/pi-templates/websearcher

# Surface the pinned version on the image's ENV so the P.1 test's Phase 1
# `docker image inspect` cross-check finds it without needing a running
# container (same shape as Dockerfile.websearcher).
ENV PLAYWRIGHT_MCP_VERSION=${PLAYWRIGHT_MCP_VERSION}

USER worker
WORKDIR /workspace
