FROM rs-sandbox-box:latest

# rs-sandbox-box-browser — a disposable sandbox box with a browser bundled in:
# rs-sandbox-box + @playwright/mcp + Chromium, wired into the box's claude as a
# stdio MCP. Opt-in (`rs-sandbox create --browser`) because Chromium is heavy —
# plain boxes stay lean.
#
# This lifts ONLY the playwright tool bundle from the websearcher image (same
# version pins, same render-extra-mcps.py source-of-truth, same managed-settings
# deny of browser_evaluate) — NOT its role.md / harness. The box's claude gets
# browser tools; the PI drives them however they like.
#
# Version pins are deliberate (rebuild + project recreate to bump), same
# discipline as the websearcher image they mirror.

USER root
ARG NODE_MAJOR=22
ARG PLAYWRIGHT_MCP_VERSION=0.0.41
ARG PYYAML_VERSION=6.0.2

# Node.js (NodeSource pin) + dumb-init (subreaper for the Playwright ->
# Chromium subprocess tree, per the websearcher image's reasoning).
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs dumb-init && \
    rm -rf /var/lib/apt/lists/* && \
    node --version && npm --version && dumb-init --version

# pyyaml for the build-time render step (harmless to leave installed).
RUN /opt/conda/bin/pip install --no-cache-dir "pyyaml==${PYYAML_VERSION}"

# @playwright/mcp + Chromium, installed at build (never `npx -y` at runtime).
# PLAYWRIGHT_BROWSERS_PATH is system-wide so the runtime `worker` user reads
# the same Chromium the build-time root install wrote.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npm install -g "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" && \
    mkdir -p ${PLAYWRIGHT_BROWSERS_PATH} && \
    cd "$(npm root -g)/@playwright/mcp" && \
    PATH="$PWD/node_modules/.bin:$PATH" \
        playwright install --with-deps chromium && \
    chmod -R a+rX ${PLAYWRIGHT_BROWSERS_PATH} && \
    rm -rf /var/lib/apt/lists/*

# Render the three image-baked artifacts from the SAME source-of-truth the
# websearcher role uses:
#   /opt/sandbox-box/extra-mcps.json          — the playwright MCP server decl;
#                                               the box entrypoint copies it to
#                                               /workspace/.mcp.json so the box's
#                                               claude auto-discovers it.
#   /opt/sandbox-box/playwright-mcp-config.json — Chromium launch flags
#                                               (referenced via --config).
#   /etc/claude-code/managed-settings.json    — denies browser_evaluate et al.
#                                               (highest-precedence permission
#                                               scope; not bypassable).
COPY container/role-mcp/websearcher/extra-mcps.yaml      /tmp/extra-mcps.yaml
COPY container/role-mcp/websearcher/render-extra-mcps.py /tmp/render-extra-mcps.py
RUN /opt/conda/bin/python3 /tmp/render-extra-mcps.py \
        --yaml                 /tmp/extra-mcps.yaml \
        --bin                  "$(command -v mcp-server-playwright)" \
        --out-extra            /opt/sandbox-box/extra-mcps.json \
        --out-config           /opt/sandbox-box/playwright-mcp-config.json \
        --out-managed-settings /etc/claude-code/managed-settings.json && \
    chmod 644 /etc/claude-code/managed-settings.json && \
    rm /tmp/extra-mcps.yaml /tmp/render-extra-mcps.py

# Entrypoint is inherited from rs-sandbox-box — it copies the baked
# extra-mcps.json to /workspace/.mcp.json when present (this image), so no
# per-image entrypoint is needed.

USER worker
WORKDIR /workspace
ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
