FROM rs-minimal-base:latest

# rs-substrate-base — rs-minimal-base + the sysbox docker-in-docker delta
# (WORKFLOW_TAXONOMY_S1.md image carve). Everything common to a project
# container (sshd, byobu, the `research` user, conda, code-server, byobu status)
# lives in rs-minimal-base; this image adds ONLY what DIND needs: the DIND apt
# deps + crun, docker-ce, the crun daemon.json, and the research user's `docker`
# group membership. The two per-flavor leaves FROM this are unchanged:
#
#   rs-supervisor  (research projects) = base + claude + rs-worker/rs-pi/
#                  rs-role-mcp + mcp-proxy tooling + inner-firewall + the
#                  CLAUDE.md/setup.sh templates + entrypoint.supervisor.sh
#   rs-management  (--type sandbox)    = base + rs-sandbox + entrypoint.management.sh
#
# The split is the point: editing the supervisor's AGENT layer can never touch
# Management, and editing the DIND delta here cascades to both leaves but NOT to
# the dind-less rs-minimal substrate.

ENV DEBIAN_FRONTEND=noninteractive

# DIND support deps + crun (the inner OCI runtime). Split out of rs-minimal-base
# because the `docker` substrate (rs-minimal) needs none of them.
RUN apt-get update && apt-get install -y --no-install-recommends \
    iptables \
    fuse-overlayfs \
    uidmap \
    crun \
    && rm -rf /var/lib/apt/lists/*

# Install Docker CE from Docker's official installer, pinned to a specific
# version. Upgrade is explicit: bump DOCKER_VERSION, re-run `research setup`,
# destroy/create affected projects. crun (above) is configured below as
# dockerd's default OCI runtime so inner containers don't hit sysbox's procfs
# incompatibility with docker's bundled runc.
ARG DOCKER_VERSION=29.5.3
RUN curl -fsSL https://get.docker.com | VERSION=${DOCKER_VERSION} sh && \
    rm -rf /var/lib/apt/lists/*

# Point the inner dockerd at crun as the default OCI runtime, and trust the local
# extension registry (STAGE_FEATURE_STAGING C1) as an insecure (plain-HTTP)
# registry. The registry is reached at rs-registry:5000 over the per-project
# network (the inner dockerd pulls extension images by container DNS); it must
# match sandbox.EXT_REGISTRY exactly. Host pushes go via a loopback port, which
# Docker trusts by default, so ONLY the inner daemon needs this entry.
RUN mkdir -p /etc/docker && cat > /etc/docker/daemon.json <<'JSON'
{
  "default-runtime": "crun",
  "runtimes": {
    "crun": {
      "path": "/usr/bin/crun"
    }
  },
  "insecure-registries": ["rs-registry:5000"]
}
JSON

# docker-ce's install created the `docker` group; add research to it for inner
# dockerd access. Deferred from rs-minimal-base, where the group didn't exist.
RUN usermod -aG docker research

# No skel snapshot, no USER switch, no ENTRYPOINT here — the leaf images add
# their flavor layer, snapshot the home, and set the entrypoint.
