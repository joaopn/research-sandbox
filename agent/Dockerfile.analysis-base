FROM continuumio/miniconda3:latest

ENV DEBIAN_FRONTEND=noninteractive

# Minimal system tools. NO git (structural requirement — later stages depend on
# this). No sshd either; workers are attached via `docker exec` from the
# supervisor. Byobu stays so `worker_attach_command` can drop the user into
# a preserved session.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl jq nano \
    byobu \
    sudo \
    locales \
    tini \
    && rm -rf /var/lib/apt/lists/*

RUN sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen && locale-gen
ENV LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8

# Non-root user at UID 1000 (matches supervisor's `research` UID so
# bind-mounted workspace subdirs are read/writable).
RUN useradd -m -s /bin/bash -G sudo -u 1000 worker && \
    echo "worker ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/worker

RUN su - worker -c "/opt/conda/bin/conda init bash"

# Data-science stack via conda — pandas, numpy, polars, duckdb, matplotlib,
# seaborn, plotly, scikit-learn, scipy, statsmodels, jupyter, papermill, tqdm.
# Installed into the base env so `python` and `jupyter` are on PATH for all
# users without activation gymnastics.
RUN /opt/conda/bin/conda install -n base -y -c conda-forge \
        pandas numpy polars pyarrow duckdb \
        matplotlib seaborn plotly \
        scikit-learn scipy statsmodels \
        jupyter ipykernel nbformat papermill tqdm \
    && /opt/conda/bin/conda clean -afy

# Claude Code is NOT baked for the worker user — it's deployed at boot via `cp`
# from the supervisor-staged agent dist (no bake anywhere; STAGE_AGENT_DIST slice
# 2). This image (+ everything FROM it — workers, role-MCPs, PI, sandbox-box) is
# now agent-agnostic. We keep ~/.local/bin on PATH (captured into worker-skel
# below) so the deployed launcher is found; the dist arrives via an RO mount.
RUN su - worker -c 'echo "export PATH=\"\$HOME/.local/bin:\$PATH\"" >> ~/.bashrc'

# Minimal byobu status line — only the time widget on the right, nothing
# extra crowding the bar. Must be staged before the skel snapshot below.
# Inherited unchanged by rs-pi-base (FROM rs-analysis-base).
RUN install -d -o worker -g worker /home/worker/.byobu /home/worker/.byobu/bin
COPY --chown=worker:worker agent/byobu-status      /home/worker/.byobu/status
COPY --chown=worker:worker agent/byobu-bin-rolename /home/worker/.byobu/bin/60_rolename
RUN chmod +x /home/worker/.byobu/bin/60_rolename

# Home skel for volume-mount first-boot restore.
RUN cp -a /home/worker /etc/worker-skel

COPY agent/entrypoint.worker.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER worker
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
