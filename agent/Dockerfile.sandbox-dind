FROM rs-substrate-base:latest

# rs-sandbox-dind — the substrate for a `--workflow sandbox-dind` project: the
# sandbox flavor PLUS inner Docker (DIND), the leaf on top of rs-substrate-base
# (STAGE_SANDBOX_DIND_AGENT).
#
# The agent (claude) is dist-delivered at boot (cp from the host-staged
# /opt/agent-dist into ~/.local) — NOT baked. The rs-sandbox box-management CLI is
# likewise NOT baked: it is the OPT-IN box harness (--with-boxes), staged into
# /usr/local/bin at create by _stage_rs_sandbox. So this image carries only the
# substrate + entrypoint; what runs inside (agent, box harness) is delivered
# per-project.

# Keep ~/.local/bin (where the dist-deployed agent launcher lands) on PATH,
# captured into the skel below so the restored home + every login shell sees it.
# rs-substrate-base / rs-minimal-base don't export it (mirrors Dockerfile.supervisor).
RUN su - research -c 'echo "export PATH=\"\$HOME/.local/bin:\$PATH\"" >> ~/.bashrc'

# Snapshot the home (byobu from the base + the PATH export) for first-boot restore.
RUN cp -a /home/research /etc/research-skel

COPY agent/entrypoint.sandbox-dind.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER research
WORKDIR /home/research

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
