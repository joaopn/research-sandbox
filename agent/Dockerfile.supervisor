FROM rs-substrate-base:latest

# rs-supervisor — research-project substrate. The agent leaf on top of
# rs-substrate-base: claude + the worker/PI/role-MCP management CLIs + the
# mcp-proxy tooling + the inner firewall + the supervisor's CLAUDE.md / setup
# templates. The shared DIND/ssh/byobu/code-server substrate lives in the base.

# Install Claude Code CLI into the research user's home at build time. Version
# pinned (versions.env → --build-arg) so a `--rebuild` refetches rather than
# caching the install layer forever; install host is downloads.claude.ai. Outer
# double-quotes so the build ARG expands before `su -` resets the env.
ARG CLAUDE_CODE_VERSION=stable
RUN su - research -c "curl -fsSL https://claude.ai/install.sh | bash -s -- ${CLAUDE_CODE_VERSION}" && \
    su - research -c 'echo "export PATH=\"\$HOME/.local/bin:\$PATH\"" >> ~/.bashrc'

# rs-worker CLI runtime deps — docker-py + pyyaml into the conda base env.
RUN /opt/conda/bin/pip install --no-cache-dir 'docker>=7.1' 'pyyaml>=6'

# rs-worker is the worker-lifecycle CLI; rs-audit-stop is the supervision-audit
# Stop hook, wired into ~/.claude/settings.json by setup.sh on first boot.
COPY cli/rs_worker.py /usr/local/bin/rs-worker
COPY cli/rs_audit_stop.py /usr/local/bin/rs-audit-stop
RUN chmod +x /usr/local/bin/rs-worker /usr/local/bin/rs-audit-stop

# MCP proxy support — config renderer + the reload helper that SIGHUPs the
# inner-daemon mcp-proxy container.
RUN mkdir -p /opt/mcp-proxy-tools
COPY container/supervisor/mcp_render_config.py /opt/mcp-proxy-tools/mcp_render_config.py
COPY container/supervisor/mcp-reload.sh /usr/local/bin/mcp-reload
RUN chmod +x /usr/local/bin/mcp-reload

# Stage 2.3 inner-netns firewall (opt-in via RS_INNER_FIREWALL=1).
COPY container/supervisor/inner-firewall.sh /usr/local/bin/rs-inner-firewall
RUN chmod +x /usr/local/bin/rs-inner-firewall

# PI-role substrate CLI (attach + manual `rs-pi sync-creds` cred bridge).
COPY agent/scripts/rs-pi              /usr/local/bin/rs-pi
RUN chmod +x /usr/local/bin/rs-pi

# role-MCP-side companion to rs-pi (`list` + `sync-creds`).
COPY agent/scripts/rs-role-mcp        /usr/local/bin/rs-role-mcp
RUN chmod +x /usr/local/bin/rs-role-mcp

# Claude Code settings + role templates (written into /workspace/.claude/ by
# the entrypoint on first boot). Kept as image artifacts to stay declarative.
RUN mkdir -p /opt/claude-templates /opt/claude-templates/commands
COPY container/supervisor/setup.sh /opt/claude-templates/setup.sh
COPY container/supervisor/CLAUDE.md /opt/claude-templates/CLAUDE.md
COPY container/supervisor/commands/ /opt/claude-templates/commands/
COPY container/supervisor/logbook_supervisor_template.md /opt/claude-templates/logbook_supervisor_template.md
COPY container/supervisor/logbook_pi_template.md /opt/claude-templates/logbook_pi_template.md
COPY container/analysis/CLAUDE.md.template /opt/claude-templates/worker.CLAUDE.md.template
RUN chmod +x /opt/claude-templates/setup.sh

# Snapshot the (now claude-equipped) home — volume mount on /home/research
# hides image contents, so the entrypoint restores from this skel on first boot.
RUN cp -a /home/research /etc/research-skel

COPY agent/entrypoint.supervisor.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER research
WORKDIR /home/research

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
