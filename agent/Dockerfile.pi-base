FROM rs-analysis-base:latest

# PI-role base layer. Adds byobu (session persistence across webui tab
# close/reopen) on top of analysis-base, plus the generic PI entrypoint.
# Per-role images (rs-pi-echo, rs-pi-wrangler, etc.) FROM this and only
# bake in the role-specific role.md under /opt/pi-templates/<role>/.

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
        byobu \
    && rm -rf /var/lib/apt/lists/*

# Generic PI entrypoint: cred copy, workspace-template staging, then
# `tail -f /dev/null` to keep the container up. Per-role images do not
# override; they bake role.md only.
COPY agent/entrypoint.pi.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# /opt/pi-templates/<role>/role.md staged in per-role layer images.
RUN mkdir -p /opt/pi-templates && chown -R worker:worker /opt/pi-templates

# Starting-message helper (STAGE_SPAWN_GREETING): cat a greeting file, then exec
# a login shell. Called as the byobu new-session command by every PI-style tab
# (Wrangler/Websearcher/pi-isolated) so the MOTD shows without auto-starting
# claude and without single-quote nesting in the tab's docker-exec wrapper.
COPY container/pi/greet-and-shell.sh /opt/pi-templates/greet-and-shell.sh
RUN chmod +x /opt/pi-templates/greet-and-shell.sh

# Bake the artifact-manifest verb (STAGE_SANDBOX_ARTIFACTS). Stdlib-only, so it
# runs in every sandbox descendant — baked roles AND rs-pi-isolated, which is
# FROM this image — regardless of the agent runtime. Invoked by the agent
# (`manifest describe <file> "..."`) and by the baked Stop-hook gate
# (`manifest gate`). Shebang is pinned to `/opt/conda/bin/python` (repo
# convention for baked CLIs) so it runs PATH-independently from both the
# hook exec context and a bare `docker exec`.
COPY cli/rs_manifest.py /usr/local/bin/manifest
RUN chmod +x /usr/local/bin/manifest

USER worker
WORKDIR /workspace

# Bake the PI's claude config (NOT auth). PI containers are PI-owned and boot
# un-authed — creds arrive via in-tab /login or `rs-pi sync-creds`
# (STAGE_PI_AUTH_OWNERSHIP). But config still ships from the image: interactive
# `claude` in a PI tab runs WITHOUT a --permission-mode flag (unlike the
# headless worker/role-MCP paths), so it reads defaultMode from settings.json.
# Without this, every PI tab would permission-prompt on every tool call. It
# also carries ONE `hooks` key: a Stop hook running `manifest gate` — the
# artifact-contract gate (STAGE_SANDBOX_ARTIFACTS) that won't let a session end
# while a file in published/ is undescribed. This is OUR gate, distinct from the
# supervisor's rs-audit-stop, which is NOT present here.
# /home/worker is image-resident (only /workspace is bind-mounted; ~/.bashrc
# is present so entrypoint's skel-restore is skipped), so this persists at
# runtime for both pi-roles and pi-isolated (rs-pi-base is their ancestor).
RUN mkdir -p /home/worker/.claude && \
    printf '%s\n' \
      '{' \
      '  "permissions": {' \
      '    "defaultMode": "bypassPermissions"' \
      '  },' \
      '  "theme": "dark",' \
      '  "hooks": {' \
      '    "Stop": [' \
      '      { "hooks": [ { "type": "command", "command": "/usr/local/bin/manifest gate" } ] }' \
      '    ]' \
      '  }' \
      '}' > /home/worker/.claude/settings.json && \
    chmod 600 /home/worker/.claude/settings.json

# Bake the uniform artifact-contract overlay as user memory. Auto-discovered by
# every interactive claude session in this container (and descendants) REGARDLESS
# of cwd — so it reaches baked roles and rs-pi-isolated alike, on top of the
# role/repo prompt, teaching the published/ vs internal/ split and the verb. This
# is the one RS convention deliberately imposed on isolated agents (the uniform
# overlay constraint); it stays minimal so it doesn't crowd the role/repo voice.
COPY --chown=worker:worker container/pi/artifact-contract.md /home/worker/.claude/CLAUDE.md

# tini comes from analysis-base. PID 1 is tini; entrypoint is /entrypoint.sh.
ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
