FROM rs-ext-base:latest

# rs-ext-websearcher — the websearcher PI role re-based as a portable EXTENSION
# node (STAGE_FEATURE_STAGING C1). Same functionality as the old rs-pi-websearcher
# (Node + @playwright/mcp + Chromium + the role/MCP render), but built on the clean
# rs-ext-base instead of rs-pi-base — so it carries NONE of the rs-analysis-base
# research-worker lineage.
#
# It re-bakes, as a PER-NODE OPT-IN, the slice of the old rs-pi-base overlay it
# actually wants: the artifact-contract verb + Stop-hook gate + claude config —
# because this node feeds a research supervisor's published/ inventory
# (STAGE_SANDBOX_ARTIFACTS). A generic/non-research ext node would omit that block.
#
# Built by _build_images as rs-ext-websearcher:${EXT_WEBSEARCHER_VERSION}, pushed
# to the local registry as ext-websearcher:<pin> at first `enable`, pulled by a
# project's inner dockerd as rs-registry:5000/ext-websearcher:<pin>. PW1 lockstep
# with Dockerfile.websearcher (PLAYWRIGHT_MCP_VERSION) is preserved — both consume
# container/role-mcp/websearcher/extra-mcps.yaml as the single source of truth.

USER root

# --- Pinned versions (PW1 lockstep with Dockerfile.websearcher) --------------
ARG NODE_MAJOR=22
ARG PLAYWRIGHT_MCP_VERSION=0.0.76
ARG PYYAML_VERSION=6.0.3

# --- Node.js + dumb-init -----------------------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - && \
    apt-get update && \
    apt-get install -y --no-install-recommends nodejs dumb-init && \
    rm -rf /var/lib/apt/lists/* && \
    node --version && npm --version && dumb-init --version

# --- pyyaml for the render step ---------------------------------------------
RUN /opt/conda/bin/pip install --no-cache-dir "pyyaml==${PYYAML_VERSION}"

# --- @playwright/mcp + Chromium runtime --------------------------------------
# Install at image-build (substrate SB3) — never `npx -y` at runtime.
# PLAYWRIGHT_BROWSERS_PATH puts Chromium in a system-wide location so the runtime
# `worker` user reads what the build-time root install wrote.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npm install -g "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" && \
    mkdir -p ${PLAYWRIGHT_BROWSERS_PATH} && \
    cd "$(npm root -g)/@playwright/mcp" && \
    PATH="$PWD/node_modules/.bin:$PATH" \
        playwright install --with-deps chromium && \
    chmod -R a+rX ${PLAYWRIGHT_BROWSERS_PATH} && \
    rm -rf /var/lib/apt/lists/*

# --- Opt-in artifact contract (was rs-pi-base; now per-node) -----------------
# This node publishes deliverables to a research supervisor's inventory, so it
# opts INTO the STAGE_SANDBOX_ARTIFACTS contract baked here (NOT in rs-ext-base):
#   - the `manifest` verb (stdlib-only; PATH-independent via the conda shebang),
#   - a settings.json carrying bypassPermissions (interactive PI claude runs with
#     no --permission-mode flag, so it reads defaultMode here) + ONE Stop hook
#     running `manifest gate` — the gate that won't idle while a published/ file is
#     undescribed (OUR gate; the supervisor's rs-audit-stop is NOT present here),
#   - the uniform artifact-contract user-memory overlay (auto-discovered regardless
#     of cwd).
COPY cli/rs_manifest.py /usr/local/bin/manifest
RUN chmod +x /usr/local/bin/manifest
RUN mkdir -p /home/worker/.claude && \
    printf '%s\n' \
      '{' \
      '  "permissions": {' \
      '    "defaultMode": "bypassPermissions"' \
      '  },' \
      '  "theme": "dark",' \
      '  "hooks": {' \
      '    "Stop": [' \
      '      { "hooks": [ { "type": "command", "command": "/usr/local/bin/manifest gate" } ] }' \
      '    ]' \
      '  }' \
      '}' > /home/worker/.claude/settings.json && \
    chmod 600 /home/worker/.claude/settings.json && \
    chown -R worker:worker /home/worker/.claude
COPY --chown=worker:worker container/pi/artifact-contract.md /home/worker/.claude/CLAUDE.md

# --- Role files --------------------------------------------------------------
# PI-mode role.md (conversational) + the Websearcher tab's starting message.
COPY container/pi-websearcher/role.md  /opt/pi-templates/websearcher/role.md
COPY container/pi-websearcher/greeting /opt/pi-templates/websearcher/greeting

# --- Render the image-baked JSON artifacts (PW2 shared source) ---------------
# Reuse the worker-facing websearcher's YAML source-of-truth; same renderer, only
# the output paths differ (PI template dir). Single deny-list by construction.
COPY container/role-mcp/websearcher/extra-mcps.yaml      /tmp/extra-mcps.yaml
COPY container/role-mcp/websearcher/render-extra-mcps.py /tmp/render-extra-mcps.py
RUN mkdir -p /etc/claude-code /opt/pi-templates/websearcher && \
    /opt/conda/bin/python3 /tmp/render-extra-mcps.py \
        --yaml                 /tmp/extra-mcps.yaml \
        --bin                  "$(command -v playwright-mcp)" \
        --out-extra            /opt/pi-templates/websearcher/extra-mcps.json \
        --out-config           /opt/pi-templates/websearcher/playwright-mcp-config.json \
        --out-managed-settings /etc/claude-code/managed-settings.json && \
    chmod 644 /etc/claude-code/managed-settings.json && \
    rm /tmp/extra-mcps.yaml /tmp/render-extra-mcps.py

# --- Version marker + permissions -------------------------------------------
RUN echo "${PLAYWRIGHT_MCP_VERSION}" > /opt/pi-templates/websearcher/.playwright-mcp-version && \
    chown -R worker:worker /opt/pi-templates/websearcher

# Surface the pinned version on the image ENV (same shape as Dockerfile.websearcher)
# so a `docker image inspect` cross-check finds it without a running container.
ENV PLAYWRIGHT_MCP_VERSION=${PLAYWRIGHT_MCP_VERSION}

USER worker
WORKDIR /workspace
