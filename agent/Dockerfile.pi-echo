FROM rs-pi-base:latest

# pi-echo — the no-op test fixture for the PI substrate (P.0). Verifies
# image build, container lifecycle, network attachment, bind-mount
# layout, cred propagation, firewall whitelist, webui registry, and
# _recreate_supervisor survival WITHOUT running `claude`. The webui tab's
# `command` field opens `bash -l` in byobu, not claude — so role.md is
# never consulted at runtime. role.md exists here only for parity with
# real per-role images (pi-wrangler, pi-librarian, etc.), so substrate
# assertions can find the same layout.

USER root
COPY container/pi-echo/role.md /opt/pi-templates/echo/role.md
RUN chown -R worker:worker /opt/pi-templates/echo

USER worker
WORKDIR /workspace
