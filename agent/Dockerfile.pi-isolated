FROM rs-pi-base:latest

# rs-pi-isolated — the generic PI-isolated agent image. ONE image for every
# isolated type; type-specific behavior comes entirely from the repo cloned
# at enable time, never from this image. RS bakes no harness here and ships
# no pre-baked types (see PLAN/STAGE_PI_ISOLATED.md, .claude/CLAUDE.md).
#
# Difference from rs-pi-base: `git` (to clone the harness repo) and a
# dedicated entrypoint that clones/checks-out/sets-up the repo before the
# container goes idle. Everything else — byobu, claude, cred staging shape —
# is inherited unchanged.
#
# The cloned repo's CLAUDE.md/skills auto-discover into this container's
# claude session and are the ONLY conventions present: the supervisor's
# /workspace/ (and its CLAUDE.md hierarchy) is structurally absent here, so
# a harness's instructions cannot collide with RS worker/supervisor rules.

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
    && rm -rf /var/lib/apt/lists/*

# Generic isolated entrypoint: cred copy (inherited shape from
# entrypoint.pi.sh), then clone/checkout/setup the harness repo, then
# `tail -f /dev/null`. Overrides rs-pi-base's /entrypoint.sh.
COPY agent/entrypoint.pi-isolated.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER worker
WORKDIR /workspace

# tini comes from analysis-base via rs-pi-base. PID 1 is tini.
ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
