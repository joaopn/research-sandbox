FROM rs-ext-base:latest

# rs-pi-isolated — the generic PI-isolated agent image. ONE image for every
# isolated type; type-specific behavior comes entirely from the repo cloned
# at enable time, never from this image. RS bakes no harness here and ships
# no pre-baked types (see PLAN/STAGE_PI_ISOLATED.md, .claude/CLAUDE.md).
#
# Rebased onto rs-ext-base (STAGE_FEATURE_STAGING lane-3): research-DECOUPLED and
# registry-delivered (pull, not save/load). DROPS the RS artifact-contract: an
# isolated BYO agent is now FULLY PRIVATE — no `manifest` verb, no Stop-hook gate,
# no published/ surface — so it cannot publish back to the research supervisor's
# inventory (matches the BYO-isolation philosophy; the contract was the one RS
# convention rs-pi-base imposed, and lane-3 sheds it for isolated agents).
#
# Difference from rs-ext-base: `git` (to clone the harness repo), a hook-free
# bypassPermissions settings.json (rs-ext-base bakes none; rs-pi-base used to), and
# a dedicated entrypoint that clones/checks-out/sets-up the repo before idling.
#
# The cloned repo's CLAUDE.md/skills auto-discover into this container's claude
# session and are the ONLY conventions present: the supervisor's /workspace/ (and
# its CLAUDE.md hierarchy) is structurally absent, so a harness's instructions
# cannot collide with RS worker/supervisor rules.

USER root

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
    && rm -rf /var/lib/apt/lists/*

# Hook-free bypassPermissions config (was inherited from rs-pi-base; rs-ext-base
# omits it). NO Stop-hook / manifest gate — this agent carries no artifact
# contract. Interactive claude reads defaultMode here and runs without a
# --permission-mode flag.
RUN mkdir -p /home/worker/.claude && \
    printf '%s\n' '{"permissions": {"defaultMode": "bypassPermissions"}, "theme": "dark"}' \
        > /home/worker/.claude/settings.json && \
    chmod 600 /home/worker/.claude/settings.json && \
    chown -R worker:worker /home/worker/.claude

# Generic isolated entrypoint: agent/editor dist cp + clone/checkout/setup the
# harness repo, then `tail -f /dev/null`. Overrides rs-ext-base's entrypoint.pi.sh.
COPY agent/entrypoint.pi-isolated.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER worker
WORKDIR /workspace

# tini comes from rs-ext-base. PID 1 is tini.
ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
